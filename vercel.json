{
    "experimentalServices": {
        "frontend": {
            "entrypoint": "frontend",
            "routePrefix": "/",
            "framework": "vite"
        },
        "backend": {
            "entrypoint": "backend",
            "routePrefix": "/_/backend"
        }
    },
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://osmo-4ws7.onrender.com/api/:path*"
        },
        {
            "source": "/temp/:path*",
            "destination": "https://osmo-4ws7.onrender.com/temp/:path*"
        }
    ]
}