{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://osmo-backend.onrender.com/api/:path*"
    },
    {
      "source": "/temp/:path*",
      "destination": "https://osmo-backend.onrender.com/temp/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}